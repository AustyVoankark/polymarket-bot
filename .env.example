# Polymarket API Credentials
# Get these from: https://polymarket.com/portfolio/api-keys
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_CHAIN_ID=137

# Trading Settings
TRADE_SIZE_USDC=10.0
MIN_MARKET_LIQUIDITY=1000.0
VOLUME_THRESHOLD_MULTIPLIER=1.0
VOLUME_AVERAGE_PERIODS=20

# Market Settings
MARKET_REFRESH_INTERVAL=60
CANDLE_TIMEFRAME_MINUTES=5

# Retry Settings
MAX_RETRIES=3
INITIAL_RETRY_DELAY=1.0
RETRY_BACKOFF_MULTIPLIER=2.0

# Logging Settings
LOG_FILE=trading_log.txt
LOG_LEVEL=INFO
